
shared {
    let A = 1;
    let B = 0;
    let Start = false;
}
program A() {
    await Start;

    await receive in (x,y);

    print("received", x,y);

    await first {
        receive in (x,y) => {
            print("first received ", x, y);
        }
        A == x => {
            print("first A == x");
        }
    }


}

main {
    let pa = run A();

    channel self.out (int, bool)> pa.in;
    channel self.out2 (int, bool)> pa.in;
    Start = true;
    send out (125, true);
    send out2 (125, false);

}